{
  "name": "Playwright Codegen Recording",
  "steps": [
    "await page.goto('https://example.com/signup')",
    "await page.click('text=Sign Up')",
    "await page.fill('[placeholder=\"Enter your name\"]', 'John Doe')",
    "await page.fill('[placeholder=\"Enter your email\"]', 'john@example.com')",
    "await page.fill('[type=\"password\"]', 'securepass123')",
    "await page.click('button:has-text(\"Create Account\")')",
    "await page.waitForSelector('text=Welcome John')",
    "await page.screenshot({ path: 'signup-success.png' })"
  ]
}