{
  "name": "Login Test",
  "actions": [
    {
      "type": "goto",
      "url": "https://example.com/login"
    },
    {
      "type": "fill",
      "selector": "[name=\"email\"]",
      "value": "test@example.com"
    },
    {
      "type": "fill",
      "selector": "[name=\"password\"]",
      "value": "password123"
    },
    {
      "type": "click",
      "selector": "button[type=\"submit\"]"
    },
    {
      "type": "waitForSelector",
      "selector": ".welcome-message"
    },
    {
      "type": "screenshot",
      "name": "login_success"
    }
  ]
}