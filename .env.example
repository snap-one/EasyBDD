# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# AWS Credentials (optional - framework uses AWS CLI config by default)
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_DEFAULT_REGION=us-east-1

# API Authentication
# API_USERNAME=your_api_username
# API_PASSWORD=your_api_password
# STAGING_USER=staging_username
# STAGING_PASS=staging_password

# API Gateway
# API_GATEWAY_KEY=your_api_gateway_key

# Legacy System
# LEGACY_USER=legacy_username
# LEGACY_PASS=legacy_password

# OAuth2
# OAUTH_CLIENT_ID=your_oauth_client_id
# OAUTH_CLIENT_SECRET=your_oauth_client_secret

# Device Credentials
# DEVICE_USERNAME=admin
# DEVICE_PASSWORD=password123

# Datalake/Logging
# DATALAKE_ENABLED=true
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# Browser Configuration
# HEADLESS=false
# BROWSER_TYPE=chromium

# Test Environment
# TEST_ENVIRONMENT=development
# BASE_URL=https://dev.example.com
