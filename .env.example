# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# TestRail Integration
# TESTRAIL_URL=https://testrail.control4.com
# TESTRAIL_USERNAME=testautomation@snapone.com
# TESTRAIL_API_KEY=your_api_key_here
# TESTRAIL_RUN_PREFIX=EASY_BDD:          # Run name prefix to scan for (default: EASY_BDD:)
# TESTRAIL_RUNNING_STATUS_ID=7           # REQUIRED: ID of the "Running" custom status in your
                                         # TestRail instance. Check Administration > Statuses.
                                         # Different instances assign different IDs — verify yours.
# TESTRAIL_ALLOWED_PROJECT_IDS=59,81,78,77,80,79,76,74  # Optional: comma-separated project IDs
                                         # to show in the builder. Leave unset to show all projects.

# Builder AI chat assistant (Ollama)
# OLLAMA_BASE_URL=http://localhost:11434  # Also used by the crawler's AI client
# BUILDER_CHAT_MODEL=qwen2.5-coder:7b     # Must already be pulled on the Ollama host
# BUILDER_CHAT_NUM_CTX=8192                # Context window given to the model — the
                                         # framework doc + action list system prompt alone
                                         # is ~3.5k tokens, so this needs headroom above that
# BUILDER_CHAT_MAX_TOKENS=350              # Caps reply length (slow on CPU-only hosts)
# BUILDER_CHAT_KEEP_ALIVE=30m              # How long Ollama keeps the model warm between turns

# Jenkins Integration
# JENKINS_URL=http://192.168.100.100:8080
# JENKINS_USERNAME=admin
# JENKINS_API_TOKEN=your_api_token_here

# AWS Credentials (optional - framework uses AWS CLI config by default)
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_DEFAULT_REGION=us-east-1

# API Authentication
# API_USERNAME=your_api_username
# API_PASSWORD=your_api_password
# STAGING_USER=staging_username
# STAGING_PASS=staging_password

# API Gateway
# API_GATEWAY_KEY=your_api_gateway_key

# Legacy System
# LEGACY_USER=legacy_username
# LEGACY_PASS=legacy_password

# OAuth2
# OAUTH_CLIENT_ID=your_oauth_client_id
# OAUTH_CLIENT_SECRET=your_oauth_client_secret

# Device Credentials
# DEVICE_USERNAME=admin
# DEVICE_PASSWORD=password123

# WattBox / Network device credentials
# NET_PASSWORD=your_network_password
# WATTBOX_PASSWORD=your_wattbox_password

# Datalake/Logging
# DATALAKE_ENABLED=true
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# Browser Configuration
# HEADLESS=false
# BROWSER_TYPE=chromium

# Test Environment
# TEST_ENVIRONMENT=development
# BASE_URL=https://dev.example.com
